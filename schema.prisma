generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./portfolio.db"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  @@map("users")
}

model PortfolioData {
  id      Int    @id @default(1)
  content String

  @@map("portfolio_data")
}
